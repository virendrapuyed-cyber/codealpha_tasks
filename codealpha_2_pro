    "# Import required libraries\n",
    "from textblob import TextBlob\n",
    "import pandas as pd\n",
    "\n",
    "\n",
    "# Sample data (You can replace this with Amazon reviews, social media data, etc.)\n",
    "data = {\n",
    "    \"review\": [\n",
    "        \"I love this product, it is amazing\",\n",
    "        \"This product is very bad and disappointing\",\n",
    "        \"The product is okay, nothing special\",\n",
    "        \"Amazing quality and great service\",\n",
    "        \"Worst experience, I hate this product\"\n",
    "    ]\n",
    "}\n",
    "\n",
    "\n",
    "# Convert data into DataFrame\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "\n",
    "# Function to perform sentiment analysis\n",
    "def sentiment_analysis(text):\n",
    "\n",
    "    # Create TextBlob object\n",
    "    analysis = TextBlob(text)\n",
    "\n",
    "    # Get polarity score\n",
    "    # Score range: -1 = negative, 0 = neutral, +1 = positive\n",
    "    polarity = analysis.sentiment.polarity\n",
    "\n",
    "\n",
    "    # Classify sentiment\n",
    "    if polarity > 0:\n",
    "        return \"Positive\"\n",
    "\n",
    "    elif polarity < 0:\n",
    "        return \"Negative\"\n",
    "\n",
    "    else:\n",
    "        return \"Neutral\"\n",
    "\n",
    "\n",
    "\n",
    "# Apply sentiment analysis on reviews\n",
    "df[\"sentiment\"] = df[\"review\"].apply(sentiment_analysis)\n",
    "\n",
    "\n",
    "# Display results\n",
    "print(df)\n",
    "\n",
    "\n",
    "# Count total positive, negative and neutral reviews\n",
    "sentiment_count = df[\"sentiment\"].value_counts()\n",
    "\n",
    "\n",
    "# Display sentiment patterns/trends\n",
    "print(\"\\nSentiment Summary:\")\n",
    "print(sentiment_count)"
   ]
  }
